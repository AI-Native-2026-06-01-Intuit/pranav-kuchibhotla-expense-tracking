# expense-agent-svc environment template.
# Copy to .env for local runs. Never commit real secrets.
# All keys use the EXPENSE_AGENT_ prefix.

# --- Postgres for the LangGraph PostgresSaver checkpointer ---
EXPENSE_AGENT_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- MCP SSE transport published by expense-mcp-server (W7D4) ---
EXPENSE_AGENT_MCP_SSE_URL=http://127.0.0.1:8080/sse
# Signed bearer JWT accepted by the expense-mcp-server SSE middleware.
EXPENSE_AGENT_MCP_BEARER_JWT=replace-with-signed-jwt

# --- LLM + tracing credentials (never commit real keys) ---
EXPENSE_AGENT_ANTHROPIC_API_KEY=
EXPENSE_AGENT_LANGSMITH_API_KEY=
EXPENSE_AGENT_LANGSMITH_PROJECT=expense-agent-svc-dev

# --- Model + retrieval configuration ---
EXPENSE_AGENT_MODEL_NAME=claude-sonnet-4-5
EXPENSE_AGENT_RERANKER=bge-reranker-base

# --- Production-quality guardrails ---
EXPENSE_AGENT_RAGAS_SAMPLE_RATE=0.01
EXPENSE_AGENT_REQUEST_BUDGET_USD_E5=25000
EXPENSE_AGENT_RECURSION_LIMIT=25
EXPENSE_AGENT_RETRIEVAL_DEADLINE_S=3.0
EXPENSE_AGENT_API_DEADLINE_S=5.0
EXPENSE_AGENT_SYNTHESIS_DEADLINE_S=8.0

# --- HTTP surface ---
EXPENSE_AGENT_HOST=0.0.0.0
EXPENSE_AGENT_PORT=8080
EXPENSE_AGENT_ENVIRONMENT=dev

# --- LLM cost rates (integer 1e-5 USD per million tokens) ---
# BudgetGuard.record_usage uses these to compute per-request spend.
# llm-proxy / CloudWatch is the authoritative billing source.
EXPENSE_AGENT_INPUT_RATE_USD_E5_PER_MILLION=300
EXPENSE_AGENT_OUTPUT_RATE_USD_E5_PER_MILLION=1500

# --- Optional Anthropic base URL (e.g. an llm-proxy) ---
# Leave empty to use the default Anthropic endpoint.
EXPENSE_AGENT_ANTHROPIC_BASE_URL=

# --- CI / local ergonomics ---
EXPENSE_AGENT_ALLOW_EXTERNAL_EVAL_SKIP=false
