# expense-mcp-server environment (W7D4). Placeholders only — do not commit real secrets.

# Upstream Spring endpoints. Point stdio launchers at your local Spring app.
EXPENSE_MCP_ORDERS_SVC_URL=http://localhost:8080
EXPENSE_MCP_LLM_PROXY_URL=http://localhost:8080

# Bearer JWT forwarded to Spring. Use a synthetic test token; NEVER a real one.
EXPENSE_MCP_BEARER_JWT=REPLACE_WITH_TEST_JWT

# SSE cryptographic JWT verification. Both are REQUIRED to start the SSE
# transport — there is no presence-only fallback. Optionally pin the issuer
# and tune the JWKS refresh cadence.
EXPENSE_MCP_JWT_AUDIENCE=expense-mcp-server-placeholder
EXPENSE_MCP_JWKS_URL=https://idp.placeholder.internal/.well-known/jwks.json
EXPENSE_MCP_JWT_ISSUER=
EXPENSE_MCP_JWKS_CACHE_TTL_S=900

# LangSmith tracing project.
EXPENSE_MCP_LANGSMITH_PROJECT=expense-mcp-server

# Per-tool timeouts (seconds).
EXPENSE_MCP_TOOL_TIMEOUT_DEFAULT_S=5
EXPENSE_MCP_TOOL_TIMEOUT_RAG_S=30

# SSE transport binding.
EXPENSE_MCP_HOST=0.0.0.0
EXPENSE_MCP_PORT=8080

# Optional pipeline deps for the RAG tool (read from expense-ai defaults if unset).
EXPENSE_MCP_POSTGRES_DSN=
EXPENSE_MCP_REDIS_URL=
