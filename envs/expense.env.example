APP_VERSION=0.1.0
SPRING_PROFILES_ACTIVE=local
POSTGRES_DB=expense_dev
POSTGRES_USER=expense_dev
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_MONGODB_URI=mongodb://mongo:27017/expense_dev
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SPRING_KAFKA_CONSUMER_GROUP_ID=expense-local
OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4317
OTEL_SERVICE_NAME=expense-api

# Actuator readiness gate. With Kafka + Mongo + Redis + JPA starters all on the
# classpath, Spring Boot's default readiness group implicitly reflects whichever
# health indicators the auto-config attaches. On a cold GitHub runner Kafka's
# broker-api-versions probe flaps for minutes after boot, which keeps
# /actuator/health/readiness DOWN even though the API itself is serving traffic
# (see the compose-ci "readiness never returned UP within 300s" failure mode).
# Pin the readiness group to just readinessState + db so the probe reflects
# exactly what the container needs to answer HTTP requests, and disable the
# defaults so Kafka/Mongo/Redis flap can't drag the group back to DOWN.
MANAGEMENT_HEALTH_DEFAULTS_ENABLED=false
MANAGEMENT_HEALTH_DB_ENABLED=true
MANAGEMENT_HEALTH_PING_ENABLED=true
MANAGEMENT_ENDPOINT_HEALTH_GROUP_READINESS_INCLUDE=readinessState,db
MANAGEMENT_ENDPOINT_HEALTH_GROUP_LIVENESS_INCLUDE=livenessState,ping
