# expense-web local environment template.
# Copy to .env.local for a local run. Do not commit real hostnames.

# W7D5 agent service base URL. The AgentChatPanel appends
# /v1/chat/stream to this value and streams AI SDK v4 data-stream
# frames from expense-agent-svc. Leave unset to use the local default
# (http://localhost:8080).
VITE_EXPENSE_AGENT_URL=http://localhost:8080
