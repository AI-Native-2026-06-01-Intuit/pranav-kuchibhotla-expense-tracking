{
  "name": "expense-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit && vite build",
    "server": "tsx server/index.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "check": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit && eslint . && vitest run --coverage && playwright test",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@ai-sdk/react": "^1.2.0",
    "@apollo/client": "^3.11.0",
    "@hono/node-server": "^1.13.0",
    "@tanstack/react-query": "^5.59.0",
    "ai": "^4.3.0",
    "graphql": "^16.9.0",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.0.0",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.3.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "happy-dom": "^20.10.6",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.0",
    "msw": "^2.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "undici": "^8.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
